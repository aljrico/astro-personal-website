---
import PageLayout from "@/layouts/Base";
import { Icon } from "astro-icon";

const meta = {
	title: "Test DGT",
	description:
		"Spanish driving theory exam practice app for Permiso B, with real exam-style questions, visual scenarios, explanations, and offline study.",
};
---

<PageLayout meta={meta}>
	<div class="max-w-2xl">
		<div class="mb-8 flex items-center gap-4">
			<img src="/testDgtIcon.png" alt="Test DGT app icon" class="h-20 w-20 rounded-2xl" />
			<div>
				<h1 class="title mb-1 text-3xl">Test DGT</h1>
				<p class="text-gray-500">2026-present</p>
			</div>
		</div>

		<section class="mb-8">
			<p class="mb-4">
				A Spanish driving theory exam practice app for Permiso B. Test DGT combines real exam-style
				questions, visual road situations, guided theory, adaptive practice, and full exam
				simulations that match the DGT format.
			</p>
		</section>

		<div class="mb-8 flex flex-wrap gap-3">
			<a
				href="https://apps.apple.com/app/id6763710388"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 rounded-md bg-accent px-4 py-2 text-bgColor transition-all hover:opacity-80"
			>
				<Icon name="fa-brands:apple" class="h-5 w-5" />
				 App Store
			</a>
			<a
				href="https://play.google.com/store/apps/details?id=com.aljrico.flama_conducir"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 rounded-md bg-accent px-4 py-2 text-bgColor transition-all hover:opacity-80"
			>
				<Icon name="fa-brands:google-play" class="h-5 w-5" />
				 Google Play
			</a>
		</div>

		<nav aria-label="Test DGT links" class="flex flex-wrap gap-x-4 gap-y-2">
			<a href="/apps/test-dgt/privacy" class="project-link">Privacy Policy</a>
			<a href="/apps/test-dgt/terms" class="project-link">Terms of Use</a>
			<a href="/apps/test-dgt/support" class="project-link">Support</a>
		</nav>
	</div>
</PageLayout>
