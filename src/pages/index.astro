---
import SocialList from "@/components/SocialList";
import PostPreview from "@/components/blog/PostPreview";
import PageLayout from "@/layouts/Base";
import { getAllPosts, sortMDByDate } from "@/utils";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);

const projects: Array<{ title: string; date: string; href: string; icon: string }> = [
	{
		title: "Test DGT",
		date: "2026",
		href: "/apps/test-dgt",
		icon: "/testDgtIcon.png",
	},
	{
		title: "Flama Coach",
		date: "2026",
		href: "/apps/flama-coach",
		icon: "/flamaIcon.png",
	},
	{
		title: "Match Tile: Mini",
		date: "2023",
		href: "/apps/match-tile-mini",
		icon: "/miniMatchIcon.png",
	},
	{
		title: "Cookie Empire",
		date: "2022",
		href: "/apps/cookie-empire",
		icon: "https://is1-ssl.mzstatic.com/image/thumb/Purple221/v4/5e/15/4a/5e154ae1-c4c9-0b05-187f-918de949abb3/AppIcon-0-0-1x_U007epad-0-0-0-1-0-0-85-220.png/128x128bb.jpg",
	},
	{
		title: "Pizza Clicker",
		date: "2022",
		href: "/apps/pizza-clicker",
		icon: "/pizzaClickerIcon.png",
	},
	{
		title: "Coffee Galley",
		date: "2020",
		href: "/apps/coffee-galley",
		icon: "/ship_logo.png",
	},
	{
		title: "gameofthrones",
		date: "2018",
		href: "/apps/gameofthrones",
		icon: "/got_logo.png",
	},
	{
		title: "harrypotter",
		date: "2018",
		href: "/apps/harrypotter",
		icon: "/hp_logo.png",
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<script
		is:inline
		type="application/ld+json"
		set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			name: "Alejandro Rico",
			url: "https://aljrico.com",
			jobTitle: "Data Lead",
			description: "Data lead at a gaming studio. Game developer. Based near Barcelona.",
			sameAs: ["https://github.com/aljrico"],
		})}
	/>
	<section>
		<p class="mb-4">
			Data lead at a gaming studio. I also like studying companies and the stock market. When I'm
			not doing either, I make my own games. Based near Barcelona.
		</p>
	</section>
	<section class="mt-10 sm:mt-12">
		<h2 class="title mb-4 text-xl">Side Projects</h2>
		<ul class="grid max-w-2xl grid-cols-[repeat(auto-fit,minmax(13.5rem,1fr))] gap-3">
			{
				projects.map(({ href, title, date, icon }) => (
					<li>
						<a
							href={href}
							target={href.startsWith("/") ? undefined : "_blank"}
							rel={href.startsWith("/") ? undefined : "noopener noreferrer"}
							class="flex items-center gap-3 overflow-hidden rounded-xl border border-[#dededc] bg-white p-2.5"
						>
							<img src={icon} alt="" class="h-9 w-9 shrink-0 rounded-lg object-contain" />
							<span class="relative">
								<span class="block font-[550]">{title}</span>
								<span class="block text-gray-500">{date}</span>
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
	<section aria-label="Blog post list" class="mt-10 sm:mt-12">
		<h2 class="title mb-4 text-xl">Posts</h2>
		<ul class="space-y-4 sm:space-y-2">
			{
				allPostsByDate.map((p) => (
					<li class="flex flex-col gap-x-2 sm:flex-row">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>
	<section class="mt-10 sm:mt-12">
		<SocialList />
	</section>
</PageLayout>
